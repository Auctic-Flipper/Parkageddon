# Example environment file. DO NOT COMMIT real secrets.
# Copy to server/.env and fill in strong, unique values.

DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/parkageddon
FLASK_ENV=development
FLASK_DEBUG=1
# Generate a strong random value, e.g., `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SECRET_KEY=replace-with-strong-random-value
